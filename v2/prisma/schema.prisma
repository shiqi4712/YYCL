generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid()) @db.VarChar(32)
  username     String   @unique @db.VarChar(191)
  passwordHash String   @db.VarChar(191)
  role         String   @db.VarChar(32)
  displayName  String?  @db.VarChar(191)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdTopics    TrainingTopic[]    @relation("TopicCreator")
  createdScenarios TrainingScenario[] @relation("ScenarioCreator")
  sessions         TrainingSession[]

  @@map("users")
}

model TrainingTopic {
  id             String   @id @default(cuid()) @db.VarChar(32)
  trainingModule String   @default("PRE_CLASS") @db.VarChar(32)
  title          String   @db.VarChar(191)
  description    String   @db.Text
  status         String   @default("ACTIVE") @db.VarChar(32)
  createdById    String   @db.VarChar(32)
  createdBy      User     @relation("TopicCreator", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scenarios TrainingScenario[]

  @@map("training_topics")
}

model TrainingScenario {
  id            String   @id @default(cuid()) @db.VarChar(32)
  topicId       String   @db.VarChar(32)
  title         String   @db.VarChar(191)
  description   String   @db.Text
  parentPersona String   @db.Text
  openingLine   String   @db.Text
  difficulty    String   @db.VarChar(32)
  status        String   @default("ACTIVE") @db.VarChar(32)
  createdById   String   @db.VarChar(32)
  createdBy     User     @relation("ScenarioCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  topic    TrainingTopic     @relation(fields: [topicId], references: [id])
  steps    ScenarioStep[]
  sessions TrainingSession[]

  @@map("training_scenarios")
}

model ScenarioStep {
  id              String   @id @default(cuid()) @db.VarChar(32)
  scenarioId      String   @db.VarChar(32)
  order           Int
  title           String   @db.VarChar(191)
  objectionText   String   @db.Text
  evaluationFocus String   @db.Text
  createdAt       DateTime @default(now())

  scenario    TrainingScenario    @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  reviewSteps SessionReviewStep[]

  @@unique([scenarioId, order])
  @@map("scenario_steps")
}

model TrainingSession {
  id               String    @id @default(cuid()) @db.VarChar(32)
  teacherId        String    @db.VarChar(32)
  scenarioId       String    @db.VarChar(32)
  status           String    @default("ACTIVE") @db.VarChar(32)
  currentStepOrder Int       @default(1)
  totalScore       Int?
  summary          String?   @db.Text
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  updatedAt        DateTime  @updatedAt

  teacher  User             @relation(fields: [teacherId], references: [id])
  scenario TrainingScenario @relation(fields: [scenarioId], references: [id])
  messages SessionMessage[]
  review   SessionReview?

  @@map("training_sessions")
}

model SessionMessage {
  id        String   @id @default(cuid()) @db.VarChar(32)
  sessionId String   @db.VarChar(32)
  role      String   @db.VarChar(32)
  content   String   @db.Text
  stepOrder Int
  createdAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_messages")
}

model SessionReview {
  id           String   @id @default(cuid()) @db.VarChar(32)
  sessionId    String   @unique @db.VarChar(32)
  overallScore Int
  summary      String   @db.Text
  strengths    String   @db.Text
  weaknesses   String   @db.Text
  nextAction   String   @db.Text
  tagsJson     String   @db.Text
  createdAt    DateTime @default(now())

  session     TrainingSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepReviews SessionReviewStep[]

  @@map("session_reviews")
}

model SessionReviewStep {
  id             String @id @default(cuid()) @db.VarChar(32)
  reviewId       String @db.VarChar(32)
  stepId         String @db.VarChar(32)
  stepOrder      Int
  stepTitle      String @db.VarChar(191)
  score          Int
  verdict        String @db.Text
  strengths      String @db.Text
  issue          String @db.Text
  recommendation String @db.Text

  review SessionReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  step   ScenarioStep  @relation(fields: [stepId], references: [id])

  @@map("session_review_steps")
}
